# ============================================
# VPS Environment — WhatsApp Automation
# Copy this file: cp .env.example .env
# Then edit values below
# ============================================

# ---------- Domain ----------
DOMAIN=gtmgroup.co.id
EVOLUTION_SUBDOMAIN=wa
N8N_SUBDOMAIN=n8n
SSL_EMAIL=admin@gtmgroup.co.id

# ---------- PostgreSQL ----------
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secret_change_me

# ---------- Evolution API ----------
EVOLUTION_SERVER_URL=https://wa.gtmgroup.co.id
EVOLUTION_API_KEY=evo_api_key_change_me

# ---------- n8n ----------
N8N_WEBHOOK_URL=https://n8n.gtmgroup.co.id
N8N_EDITOR_BASE_URL=https://n8n.gtmgroup.co.id
N8N_USER=admin
N8N_PASSWORD=admin_change_me

# ---------- General ----------
TIMEZONE=Asia/Jakarta

# ---------- Proxy (opsional, jika VPS blokir WhatsApp) ----------
# Custom Dockerfile (evolution-proxy/) install proxychains-ng ke dalam container.
# proxychains intercept SEMUA traffic termasuk WebSocket keep-alive.
# Jika PC_PROXY_HOST & PC_PROXY_PORT di-set, entrypoint.sh otomatis aktifkan proxychains.
# Jika tidak di-set, Evolution API jalan tanpa proxy (direct connection).
#
# Setup Cloudflare WARP di host (gratis, recommended):
#   apt install cloudflare-warp
#   warp-cli registration new
#   warp-cli mode proxy        # JANGAN mode warp — nanti SSH mati!
#   warp-cli proxy port 40000
#   warp-cli connect
#
# Uncomment jika VPS blokir WhatsApp:
# PC_PROXY_HOST=127.0.0.1
# PC_PROXY_PORT=40000
# PC_PROXY_TYPE=socks5
